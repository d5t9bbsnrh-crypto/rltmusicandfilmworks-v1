---
const pageTitle = "OZONE – The Funk Strut (12-Inch Extended Digital Edition)";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <style>
      :root {
        --gold: #d4af37;
        --black: #050505;
        --white: #ffffff;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #000;
        color: var(--white);
        font-family: Arial, Helvetica, sans-serif;
        overflow-x: hidden;
      }

      .hero {
        position: relative;
        min-height: 100vh;
        background-image:
          linear-gradient(
            rgba(0,0,0,0.65),
            rgba(0,0,0,0.82)
          ),
          url('/images/hero/logos/Ozone-store.png');
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .top-nav {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 28px;
        padding: 28px 20px;
        position: relative;
        z-index: 5;
      }

      .top-nav a {
        color: white;
        text-decoration: none;
        font-size: 1rem;
        letter-spacing: 2px;
        font-weight: 700;
        transition: 0.3s ease;
      }

      .top-nav a:hover {
        color: var(--gold);
      }

      .content {
        width: 100%;
        max-width: 1200px;
        margin: auto;
        padding: 40px 20px 90px;
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 50px;
        align-items: center;
      }

      .left-panel {
        backdrop-filter: blur(6px);
      }

      .release-badge {
        display: inline-block;
        padding: 10px 18px;
        border: 2px solid #d4af37;
        color: #d4af37;
        background: rgba(0, 0, 0, 0.65);
        letter-spacing: 2px;
        margin-bottom: 24px;
        font-size: 0.95rem;
        font-weight: 800;
        border-radius: 999px;
        box-shadow: 0 0 18px rgba(212, 175, 55, 0.55);
      }

      h1 {
        font-size: 4rem;
        line-height: 1.05;
        margin-bottom: 20px;
      }

      .subtext {
        font-size: 1.2rem;
        line-height: 1.8;
        color: #dddddd;
        max-width: 700px;
        margin-bottom: 35px;
      }

      .features {
        display: grid;
        grid-template-columns: repeat(2, minmax(180px, 1fr));
        gap: 18px;
        margin-bottom: 40px;
      }

      .feature-box {
        border: 1px solid rgba(212,175,55,0.4);
        padding: 18px;
        background: rgba(255,255,255,0.04);
        border-radius: 14px;
      }

      .feature-box h3 {
        color: var(--gold);
        margin-bottom: 10px;
        font-size: 1rem;
      }

      .feature-box p {
        color: #dddddd;
        font-size: 0.95rem;
        line-height: 1.5;
      }

      .catalog {
        margin-top: 20px;
        font-size: 1rem;
        color: #cccccc;
        letter-spacing: 1px;
      }

      .buy-panel {
        background: rgba(0,0,0,0.72);
        border: 1px solid rgba(212,175,55,0.45);
        padding: 40px 30px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 0 35px rgba(0,0,0,0.5);
      }

      .price {
        font-size: 3.5rem;
        color: var(--gold);
        margin-bottom: 15px;
        font-weight: bold;
      }

      .buy-text {
        color: #dddddd;
        line-height: 1.7;
        margin-bottom: 30px;
      }

      .download-btn {
        display: inline-block;
        width: 100%;
        background: var(--gold);
        color: black;
        text-decoration: none;
        padding: 18px;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 2px;
        border-radius: 12px;
        transition: 0.3s ease;
      }

      .download-btn:hover {
        transform: scale(1.03);
        background: #f0c64f;
      }

      .included {
        margin-top: 35px;
        text-align: left;
      }

      .included h2 {
        color: var(--gold);
        margin-bottom: 18px;
        font-size: 1.1rem;
      }

      .included ul {
        list-style: none;
      }

      .included li {
        margin-bottom: 12px;
        color: #dddddd;
      }

      footer {
        width: 100%;
        text-align: center;
        padding: 30px 20px;
        font-size: 0.9rem;
        color: #888;
        background: #050505;
      }

      @media (max-width: 980px) {
        .content {
          grid-template-columns: 1fr;
          text-align: center;
        }

        .features {
          grid-template-columns: 1fr;
        }

        h1 {
          font-size: 2.8rem;
        }

        .buy-panel {
          width: 100%;
          max-width: 520px;
          margin: auto;
        }
      }

      @media (max-width: 600px) {
        .top-nav {
          gap: 18px;
          flex-wrap: wrap;
        }

        .top-nav a {
          font-size: 0.9rem;
        }

        h1 {
          font-size: 2.2rem;
        }

        .price {
          font-size: 2.7rem;
        }

        .subtext {
          font-size: 1rem;
        }

        .release-badge {
          font-size: 0.8rem;
          padding: 8px 14px;
        }
      }
    </style>
  </head>

  <body>

    <section class="hero">

      <nav class="top-nav">
        <a href="/">HOME</a>
        <a href="/store">STORE</a>
        <a href="/cart">CART</a>
        <a href="/contacts">CONTACT</a>
      </nav>

      <div class="content">

        <div class="left-panel">

          <div class="release-badge">
            12-INCH DIGITAL EDITION
          </div>

          <h1>
            OZONE<br />
            THE FUNK STRUT
          </h1>

          <p class="subtext">
            A collector-style extended digital release inspired by
            classic 12-inch vinyl editions featuring premium audio,
            expanded mixes, downloadable artwork, and exclusive
            release materials from OZONE and RLT Music & Film Works.
          </p>

          <div class="features">

            <div class="feature-box">
              <h3>EXTENDED MIX</h3>
              <p>
                Premium extended version designed for
                classic dance-floor energy.
              </p>
            </div>

            <div class="feature-box">
              <h3>HIGH QUALITY AUDIO</h3>
              <p>
                Includes WAV and high-bitrate MP3
                versions for professional playback.
              </p>
            </div>

            <div class="feature-box">
              <h3>COLLECTOR ARTWORK</h3>
              <p>
                Digital 12-inch inspired cover art
                and promotional graphics included.
              </p>
            </div>

            <div class="feature-box">
              <h3>OFFICIAL RELEASE</h3>
              <p>
                Released by RLT Music & Film Works
                in coordination with OZONE.
              </p>
            </div>

          </div>

          <div class="catalog">
            Catalog: RLT-12001<br />
            ISRC: QM-EV3-26-07779
          </div>

        </div>

        <div class="buy-panel">

          <div class="price">
            $12.99
          </div>

          <p class="buy-text">
            Download the complete 12-inch extended
            digital edition instantly after purchase.
          </p>

          <a
            class="download-btn"
            href="YOUR-STRIPE-PAYMENT-LINK"
            target="_blank"
          >
            DOWNLOAD NOW
          </a>

          <div class="included">

            <h2>INCLUDED</h2>

            <ul>
              <li>✓ Extended Mix</li>
              <li>✓ WAV + MP3 Versions</li>
              <li>✓ Digital Cover Artwork</li>
              <li>✓ Producer Credits</li>
              <li>✓ Collector Edition Package</li>
            </ul>

          </div>

        </div>

      </div>

    </section>

    <footer>
      © 2026 RLT Music & Film Works — All Rights Reserved
    </footer>

  </body>
</html>