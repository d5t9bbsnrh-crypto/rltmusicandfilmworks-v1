<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RLT Store</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        min-height: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        background: #000;
        font-family: Arial, Helvetica, sans-serif;
      }

      body {
        background: #000;
      }

      .store-page {
        position: relative;
        width: 100%;
        min-height: 100vh;
        background: #000;
      }

      .banner {
        width: 100%;
        height: auto;
        display: block;
      }

      .top-nav {
        position: absolute;
        top: 25px;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        z-index: 100;
      }

      .nav-links {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: white;
        text-decoration: none;
        font-size: 1.03rem;
        font-weight: 600;
        letter-spacing: 1px;
        transition: opacity 0.3s ease;
      }

      .nav-links a:hover {
        opacity: 0.7;
      }

      .content-section {
        width: 100%;
        padding: 60px 20px 100px;
        background: #000;
        color: white;
        text-align: center;
      }

      .content-section h1 {
        font-size: 2.2rem;
        margin-bottom: 20px;
      }

      .content-section p {
        max-width: 800px;
        margin: 0 auto;
        line-height: 1.7;
        font-size: 1rem;
      }

      @media (max-width: 768px) {
        .top-nav {
          top: 12px;
          padding: 0 10px;
        }

        .nav-links {
          gap: 16px;
          justify-content: center;
        }

        .nav-links a {
          font-size: 0.92rem;
        }

        .content-section h1 {
          font-size: 1.6rem;
        }

        .content-section p {
          font-size: 0.95rem;
        }
      }
    </style>
  </head>

  <body>
    <main class="store-page">
      <div class="top-nav">
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/music">Music</a>
          <a href="/films">Films</a>
          <a href="/partners">Partners</a>
          <a href="/contact">Contact</a>
          <a href="/cart">Cart</a>
        </nav>
      </div>

      <img
        src="/images/storebanner.PNG"
        alt="RLT Store Banner"
        class="banner"
      />

      <section class="content-section">
        <h1>RLT Store</h1>

        <p>
          Welcome to the official RLT Music & Filmworks store.
          Merchandise, music, films, collectibles, and exclusive releases
          will be available here soon.
        </p>
      </section>
    </main>
  </body>
</html>