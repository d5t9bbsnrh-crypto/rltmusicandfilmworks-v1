---

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>OZONE Store</title>

    <style>

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #000;
        font-family: Arial, Helvetica, sans-serif;
        overflow: hidden;
        color: white;
      }

      .store-page {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        background: #000;
      }

      /* HERO IMAGE */

      .hero-image {
        position: absolute;
        inset: 0;

        width: 100%;
        height: 100%;

        object-fit: contain;

        z-index: 1;
      }

      /* OVERLAY */

      .overlay {
        position: absolute;
        inset: 0;

        background: transparent;

        z-index: 2;
      }

      /* TOP NAV */

      .top-nav {
        position: absolute;

        top: 18px;
        left: 50%;

        transform: translateX(-50%);

        display: flex;
        align-items: center;
        justify-content: center;

        gap: 48px;

        padding: 14px 34px;

        background: rgba(0,0,0,0.18);

        border-radius: 18px;

        backdrop-filter: blur(10px);

        z-index: 100;
      }

      .top-nav a {
        color: #d4af37;

        text-decoration: none;

        font-size: 20px;
        font-weight: bold;

        letter-spacing: 3px;

        transition: 0.3s ease;
      }

      .top-nav a:hover {
        color: white;
      }

      /* DOWNLOAD BUTTON */

      .download-button {
        position: absolute;

        top: 18px;
        right: 3%;

        z-index: 100;
      }

      .download-button a {
        display: inline-block;

        padding: 16px 34px;

        border-radius: 16px;

        background: #d4af37;

        color: #000;

        text-decoration: none;

        font-size: 18px;
        font-weight: bold;

        letter-spacing: 2px;

        box-shadow:
          0 0 24px rgba(212,175,55,0.45);

        transition: 0.3s ease;
      }

      .download-button a:hover {
        transform: scale(1.03);

        box-shadow:
          0 0 34px rgba(212,175,55,0.75);
      }

      /* MOBILE */

      @media (max-width: 768px) {

        .top-nav {

          gap: 18px;

          padding: 12px 18px;
        }

        .top-nav a {

          font-size: 13px;

          letter-spacing: 2px;
        }

        .download-button {

          top: auto;

          bottom: 40px;

          right: 50%;

          transform: translateX(50%);
        }

        .download-button a {

          font-size: 13px;

          padding: 14px 20px;
        }

      }

    </style>

  </head>

  <body>

    <div class="store-page">

      <!-- HERO IMAGE -->

      <img
        src="/images/hero/logos/Ozone-store.png"
        alt="OZONE Store"
        class="hero-image"
      />

      <!-- OVERLAY -->

      <div class="overlay"></div>

      <!-- TOP NAVIGATION -->

      <nav class="top-nav">
        <a href="/">HOME</a>
        <a href="/store">STORE</a>
        <a href="/cart">CART</a>
      </nav>

      <!-- DOWNLOAD BUTTON -->

      <div class="download-button">
        <a
          href="https://buy.stripe.com/00w3cxdsR90U1eI2xGcfK03"
          target="_blank"
          rel="noopener noreferrer"
        >
          DOWNLOAD NOW • $4.99
        </a>
      </div>

    </div>

  </body>
</html>