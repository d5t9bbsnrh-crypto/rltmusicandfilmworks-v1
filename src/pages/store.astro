---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />

    <title>RLT Store</title>

    <style>

      *{
        margin:0;
        padding:0;
        box-sizing:border-box;
      }

      html,
      body{
        width:100%;
        overflow-x:hidden;
      }

      body{
        font-family:Arial, Helvetica, sans-serif;
        background:#000;
        color:white;
      }

      a{
        touch-action:manipulation;
      }

      .hero{
        min-height:100vh;
        background:#000;

        display:flex;
        flex-direction:column;

        position:relative;
        overflow:hidden;
      }

      .hero::before{
        content:"";

        position:absolute;

        top:50%;
        left:50%;

        transform:translate(-50%, -50%);

        width:96%;
        height:96%;

        /* CORRECT IMAGE FILE */
        background-image:url('/images/hero/logos/Ozone-store.png');

        background-size:contain;
        background-repeat:no-repeat;
        background-position:center center;

        z-index:1;

        pointer-events:none;
      }

      nav{
        width:100%;

        padding:20px 40px;

        display:flex;
        justify-content:center;
        align-items:center;

        position:fixed;
        top:0;
        left:0;

        z-index:99999;

        pointer-events:auto;
      }

      .nav-left{
        display:flex;
        align-items:center;
        gap:40px;

        padding:14px 40px;

        background:rgba(0,0,0,0.45);

        border:1px solid rgba(255,215,0,0.15);
        border-radius:20px;

        backdrop-filter:blur(12px);
      }

      nav a{
        color:white;
        text-decoration:none;

        letter-spacing:2px;
        font-size:1.35rem;
        font-weight:700;

        transition:0.3s ease;
      }

      nav a:hover{
        color:#ffd700;
      }

      .download-button{
        position:fixed;

        top:18px;
        right:24px;

        z-index:99999;

        pointer-events:auto;
      }

      .download-btn{
        display:inline-block;

        padding:18px 38px;

        background:#d9b54a;
        color:#000;

        border-radius:18px;

        text-decoration:none;

        font-weight:800;
        letter-spacing:1px;

        font-size:1.2rem;

        transition:0.3s ease;
      }

      .download-btn:hover{
        background:#fff;
        transform:translateY(-2px);
      }

      .hero-content{
        flex:1;

        display:flex;
        justify-content:center;
        align-items:center;

        position:relative;
        z-index:2;

        pointer-events:none;
      }

      /* TABLETS */

      @media (max-width:1024px){

        .hero::before{
          width:96%;
          height:96%;
          top:50%;
        }

        .download-btn{
          padding:15px 28px;
          font-size:1rem;
        }

      }

      /* PORTRAIT MOBILE ONLY */

      @media screen and (max-width:768px) and (orientation:portrait){

        body{
          overflow-x:hidden;
        }

        .hero{
          min-height:100vh;
        }

        .hero::before{

          width:96vw;
          height:86vh;

          /* CENTERED FOR UPRIGHT PHONES */
          top:50%;

          left:50%;

          transform:translate(-50%, -50%);

          background-size:contain;
          background-position:center center;
        }

        nav{
          padding:14px 10px;
        }

        .nav-left{
          gap:14px;
          padding:12px 20px;

          flex-wrap:wrap;
          justify-content:center;
        }

        nav a{
          font-size:0.92rem;
          letter-spacing:1px;
        }

        .download-button{

          top:92px;
          left:50%;
          right:auto;

          transform:translateX(-50%);
        }

        .download-btn{
          padding:12px 24px;
          font-size:0.82rem;

          border-radius:14px;
        }

      }

      /* SMALLER PHONES */

      @media (max-width:480px){

        .hero::before{

          width:98vw;
          height:82vh;

          top:50%;
        }

        .nav-left{
          gap:10px;
        }

        nav a{
          font-size:0.78rem;
        }

        .download-button{
          top:88px;
        }

        .download-btn{
          padding:11px 20px;
          font-size:0.74rem;
        }

      }

      /* VERY SMALL PHONES */

      @media (max-width:390px){

        .hero::before{

          width:100vw;
          height:80vh;

          top:50%;
        }

        nav a{
          font-size:0.72rem;
        }

        .download-btn{
          padding:10px 18px;
          font-size:0.7rem;
        }

      }

    </style>
  </head>

  <body>

    <section class="hero">

      <nav>

        <div class="nav-left">

          <a href="/">HOME</a>
          <a href="/store">STORE</a>
          <a href="/cart">CART</a>

        </div>

      </nav>

      <div class="download-button">

        <a
          href="https://buy.stripe.com/00w3cxdsR90U1eI2xGcfK03"
          class="download-btn"
        >
          DOWNLOAD NOW • $4.99
        </a>

      </div>

      <div class="hero-content"></div>

    </section>

  </body>
</html>