---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RLT Store | Music & Filmworks</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        background: #000;
        overflow: hidden;
        font-family: Arial, Helvetica, sans-serif;
      }

      .store-page {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
      }

      .store-page img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(0,0,0,0.35),
          rgba(0,0,0,0.55)
        );
      }

      .top-nav {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 35px;
        z-index: 20;
      }

      .top-nav a {
        color: white;
        text-decoration: none;
        font-size: 15px;
        letter-spacing: 2px;
        transition: 0.3s ease;
      }

      .top-nav a:hover {
        color: gold;
      }

      .home-btn {
        position: absolute;
        top: 25px;
        left: 30px;
        z-index: 20;
      }

      .home-btn a {
        color: gold;
        text-decoration: none;
        border: 1px solid gold;
        padding: 12px 20px;
        background: rgba(0,0,0,0.55);
        letter-spacing: 1px;
        transition: 0.3s ease;
      }

      .home-btn a:hover {
        background: gold;
        color: black;
      }

      .store-content {
        position: absolute;
        bottom: 100px;
        left: 70px;
        z-index: 20;
        max-width: 600px;
      }

      .store-content h1 {
        color: gold;
        font-size: 64px;
        margin-bottom: 20px;
        letter-spacing: 3px;
      }

      .store-content p {
        color: white;
        font-size: 20px;
        line-height: 1.7;
        margin-bottom: 35px;
      }

      .shop-btn {
        display: inline-block;
        color: gold;
        text-decoration: none;
        border: 1px solid gold;
        padding: 16px 34px;
        font-size: 16px;
        letter-spacing: 2px;
        background: rgba(0,0,0,0.55);
        transition: 0.3s ease;
      }

      .shop-btn:hover {
        background: gold;
        color: black;
      }

      @media (max-width: 900px) {
        .top-nav {
          gap: 18px;
          flex-wrap: wrap;
          width: 90%;
          justify-content: center;
        }

        .top-nav a {
          font-size: 12px;
        }

        .store-content {
          left: 30px;
          right: 30px;
          bottom: 60px;
        }

        .store-content h1 {
          font-size: 42px;
        }

        .store-content p {
          font-size: 17px;
        }
      }
    </style>
  </head>

  <body>
    <div class="store-page">

      <img src="/images/storebanner.png" alt="RLT Store Banner" />

      <div class="overlay"></div>

      <div class="home-btn">
        <a href="/">← HOME</a>
      </div>

      <nav class="top-nav">
        <a href="/music">MUSIC</a>
        <a href="/film">FILM</a>
        <a href="/store">STORE</a>
        <a href="/artists">ARTISTS</a>
        <a href="/ozone">OZONE</a>
        <a href="/contact">CONTACT</a>
      </nav>

      <div class="store-content">
        <h1>RLT STORE</h1>

        <p>
          Explore official RLT Music & Filmworks merchandise,
          collectibles, music releases, exclusive apparel,
          and future limited-edition drops.
        </p>

        <a class="shop-btn" href="#">
          SHOP COLLECTION
        </a>
      </div>

    </div>
  </body>
</html>