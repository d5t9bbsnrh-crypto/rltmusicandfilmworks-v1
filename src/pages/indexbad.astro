<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RLT Music & Filmworks</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        background: black;
        overflow: hidden;
        font-family: Arial, Helvetica, sans-serif;
      }

      .hero {
        position: relative;
        width: 100vw;
        height: 100vh;
        background: black;
      }

      .hero-image {
        position: absolute;
        inset: 0;
        background-image: url('/images/rlthomepage.png');
        background-position: center;
        background-repeat: no-repeat;
        background-size: contain;
      }

      .top-nav {
        position: absolute;
        top: 22px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 28px;
        z-index: 100;
      }

      .top-nav a {
        color: rgba(255,255,255,0.9);
        text-decoration: none;
        font-size: 16px;
        letter-spacing: 1px;
      }

      .top-nav a:hover {
        color: #f5c542;
      }
    </style>
  </head>

  <body>
    <section class="hero">

      <div class="hero-image"></div>

      <nav class="top-nav">
        <a href="/music">Music</a>
        <a href="/film">Film</a>
        <a href="/store">Store</a>
        <a href="/artists">Artists</a>
        <a href="/ozone">Ozone</a>
        <a href="/contacts">Contact</a>
      </nav>

    </section>
  </body>
</html>