<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RLT Shopping Cart</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: black;
        color: white;
        font-family: Arial, Helvetica, sans-serif;
        overflow-x: hidden;
      }

      .page {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-bottom: 40px;
      }

      /* NAVIGATION */

      .nav {
        width: 100%;
        display: flex;
        justify-content: center;
        gap: 18px;
        padding: 24px 12px;
        flex-wrap: wrap;
      }

      .nav a {
        color: gold;
        text-decoration: none;
        border: 1px solid rgba(255, 215, 0, 0.55);
        padding: 12px 20px;
        font-size: 18px;
        letter-spacing: 2px;
        background: rgba(0, 0, 0, 0.65);
        border-radius: 6px;
        transition: 0.25s ease;
      }

      .nav a:hover {
        background: gold;
        color: black;
      }

      /* CART BANNER */

      .hero {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 20px;
        padding-bottom: 30px;
      }

      .hero img {
        width: 92%;
        max-width: 1400px;
        height: auto;
        object-fit: contain;
        display: block;
      }

      /* CART SECTION */

      .cart-section {
        width: 92%;
        max-width: 1200px;
        margin-top: 20px;
        display: flex;
        justify-content: center;
      }

      .cart-box {
        width: 100%;
        border: 1px solid rgba(255, 215, 0, 0.3);
        border-radius: 10px;
        padding: 40px;
        background: rgba(255, 255, 255, 0.03);
        text-align: center;
      }

      .cart-box h1 {
        color: gold;
        font-size: 42px;
        margin-bottom: 20px;
        letter-spacing: 2px;
      }

      .cart-box p {
        color: #ddd;
        font-size: 20px;
        margin-bottom: 30px;
        line-height: 1.6;
      }

      .button {
        display: inline-block;
        text-decoration: none;
        color: black;
        background: gold;
        padding: 14px 24px;
        border-radius: 6px;
        font-weight: bold;
        letter-spacing: 1px;
        transition: 0.25s ease;
      }

      .button:hover {
        opacity: 0.85;
      }

      /* MOBILE */

      @media (max-width: 768px) {
        .nav {
          gap: 8px;
          padding: 14px 8px;
        }

        .nav a {
          font-size: 11px;
          padding: 9px 10px;
          letter-spacing: 1px;
        }

        .hero img {
          width: 96%;
        }

        .cart-box {
          padding: 24px;
        }

        .cart-box h1 {
          font-size: 28px;
        }

        .cart-box p {
          font-size: 16px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- NAVIGATION -->

      <nav class="nav">
        <a href="/">HOME</a>
        <a href="/music">MUSIC</a>
        <a href="/films">FILMS</a>
        <a href="/store">STORE</a>
        <a href="/contacts">CONTACT</a>
        <a href="/cart">CART</a>
      </nav>

      <!-- CART IMAGE -->

      <section class="hero">
        <img
          src="/images/cartbanner.png"
          alt="RLT Shopping Cart"
        />
      </section>

      <!-- CART CONTENT -->

      <section class="cart-section">

        <div class="cart-box">

          <h1>SHOPPING CART</h1>

          <p>
            Your cart is currently empty.
            Continue shopping to add products,
            music, apparel, films, and collectibles.
          </p>

          <a class="button" href="/store">
            RETURN TO STORE
          </a>

        </div>

      </section>

    </div>
  </body>
</html>
