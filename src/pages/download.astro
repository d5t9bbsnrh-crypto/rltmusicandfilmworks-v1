---
const songFile = "/downloads/The-Funk-Strut.zip";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Funk Strut Download</title>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: #000;
        color: white;
        font-family: Arial, sans-serif;
        text-align: center;
      }

      .container {
        padding: 100px 20px;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 20px;
      }

      p {
        font-size: 1.2rem;
        margin-bottom: 40px;
      }

      .download-btn {
        display: inline-block;
        padding: 18px 40px;
        background: gold;
        color: black;
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 10px;
      }

      .download-btn:hover {
        opacity: 0.9;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Download The Funk Strut</h1>

      <p>Your purchase was successful.</p>

      <a class="download-btn" href={songFile} download>
        Download ZIP File
      </a>
    </div>
  </body>
</html>