<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RLT Cart</title>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: #000;
        font-family: Arial, Helvetica, sans-serif;
        color: white;
        overflow-x: hidden;
      }

      .page {
        width: 100%;
        min-height: 100vh;
        position: relative;
        background: #000;
      }

      /* TOP NAVIGATION */

      .top-nav {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 30px;
        z-index: 100;
      }

      .top-nav a {
        color: #d4af37;
        text-decoration: none;
        font-size: 14px;
        font-weight: bold;
        letter-spacing: 2px;
        transition: 0.3s ease;
      }

      .top-nav a:hover {
        color: white;
      }

      /* HERO IMAGE */

      .hero-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        padding-top: 80px;
      }

      .cart-hero {
        width: 90%;
        max-width: 1400px;
        height: auto;
        display: block;
      }

      /* CART SUMMARY BUTTON */

      .cart-summary-link {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 30px;
        margin-bottom: 60px;
      }

      .cart-summary-link a {
        background: #d4af37;
        color: black;
        text-decoration: none;
        padding: 14px 34px;
        font-size: 14px;
        font-weight: bold;
        letter-spacing: 2px;
        border-radius: 4px;
        transition: 0.3s ease;
      }

      .cart-summary-link a:hover {
        background: white;
      }

      /* MOBILE */

      @media (max-width: 768px) {
        .top-nav {
          gap: 15px;
          flex-wrap: wrap;
        }

        .top-nav a {
          font-size: 12px;
        }

        .cart-hero {
          width: 95%;
        }

        .cart-summary-link a {
          font-size: 12px;
          padding: 12px 24px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- TOP NAV -->

      <nav class="top-nav">
        <a href="/">HOME</a>
        <a href="/music">MUSIC</a>
        <a href="/store">STORE</a>
        <a href="/contact">CONTACT</a>
        <a href="/cart">CART</a>
      </nav>

      <!-- CART HERO IMAGE -->

      <div class="hero-wrapper">
        <img
          src="/images/hero/logos/Ozone-cart.png"
          alt="Ozone Cart"
          class="cart-hero"
        />
      </div>

      <!-- CART SUMMARY BUTTON -->

      <div class="cart-summary-link">
        <a href="/checkout">CART SUMMARY</a>
      </div>

    </div>
  </body>
</html>