<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RLT Store</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        background: black;
        font-family: Arial, Helvetica, sans-serif;
        overflow: hidden;
      }

      body {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* TOP MENU */

      .menu {
        position: absolute;
        top: 4px;
        left: 50%;
        transform: translateX(-50%);
        width: 98%;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        z-index: 100;
        flex-wrap: wrap;
      }

      .menu a {
        color: white;
        text-decoration: none;
        font-size: 0.82rem;
        padding: 8px 14px;
        border-radius: 6px;
        background: rgba(0,0,0,0.45);
        border: 1px solid rgba(255,255,255,0.35);
        backdrop-filter: blur(6px);
        transition: all 0.3s ease;
      }

      .menu a:hover {
        background: rgba(255,255,255,0.15);
        transform: translateY(-2px);
      }

      /* CENTER CONTENT */

      .banner-wrapper {
        width: 100%;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding-top: 40px;
      }

      .banner {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }

      /* LARGE DESKTOP */

      @media (min-width: 1400px) {
        .menu a {
          font-size: 0.9rem;
          padding: 9px 16px;
        }
      }

      /* TABLETS */

      @media (max-width: 1024px) {
        .menu {
          gap: 10px;
        }

        .menu a {
          font-size: 0.75rem;
          padding: 7px 12px;
        }

        .banner-wrapper {
          padding-top: 36px;
        }
      }

      /* PHONES */

      @media (max-width: 768px) {
        .menu {
          gap: 7px;
        }

        .menu a {
          font-size: 0.68rem;
          padding: 6px 10px;
        }

        .banner-wrapper {
          padding-top: 32px;
        }
      }

      /* SMALL PHONES */

      @media (max-width: 480px) {
        .menu {
          gap: 5px;
        }

        .menu a {
          font-size: 0.62rem;
          padding: 5px 8px;
        }

        .banner-wrapper {
          padding-top: 28px;
        }
      }
    </style>
  </head>

  <body>

    <div class="menu">
      <a href="/">Home</a>
      <a href="/music">Music</a>
      <a href="/films">Films</a>
      <a href="/store">Store</a>
      <a href="/contact">Contact</a>
      <a href="/cart">🛒 Cart</a>
    </div>

    <div class="banner-wrapper">
      <img
        src="/images/storebanner.PNG"
        alt="Store Banner"
        class="banner"
      />
    </div>

  </body>
</html>