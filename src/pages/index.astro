---
const audioSrc = "/audio/the-funk-strut-preview.mp3";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RLT Music & Film Works</title>

    <style>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
        font-family: Georgia, "Times New Roman", serif;
        background: #000;
        color: #fff;
        overflow-x: hidden;
      }

      body {
        min-height: 100vh;
      }

      .page {
        position: relative;
        min-height: 100vh;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        background-image:
          linear-gradient(
            rgba(0, 0, 0, 0.18),
            rgba(0, 0, 0, 0.42)
          ),
          url("/images/hero/rlt-homepage-hero-master.png");
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        background-color: #000;
      }

      .top-nav {
        position: fixed;
        top: 18px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: clamp(18px, 3vw, 42px);
        padding: 10px 20px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.34);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        border: 1px solid rgba(255, 215, 120, 0.28);
      }

      .top-nav a {
        color: #fff7d6;
        text-decoration: none;
        font-size: clamp(0.9rem, 1.4vw, 1.1rem);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-shadow:
          0 0 8px rgba(255, 214, 98, 0.85),
          0 2px 8px rgba(0, 0, 0, 0.95);
        transition: color 0.2s ease, transform 0.2s ease;
      }

      .top-nav a:hover {
        color: #ffd36a;
        transform: translateY(-1px);
      }

      .hero-content {
        width: 100%;
        min-height: 100vh;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 90px 22px 40px;
      }

      .listen-wrap {
        position: absolute;
        right: 8%;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
      }

      .listen-button {
        cursor: pointer;
        border: 1px solid rgba(255, 221, 135, 0.82);
        border-radius: 999px;
        padding: 13px 28px;
        color: #fff7dc;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(0.9rem, 1.5vw, 1.05rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background:
          radial-gradient(circle at top, rgba(255, 215, 128, 0.22), transparent 42%),
          linear-gradient(135deg, rgba(30, 18, 5, 0.92), rgba(0, 0, 0, 0.82));
        box-shadow:
          0 0 16px rgba(255, 204, 92, 0.52),
          0 0 34px rgba(255, 204, 92, 0.24),
          inset 0 0 12px rgba(255, 255, 255, 0.08);
        text-shadow:
          0 0 8px rgba(255, 214, 98, 0.8),
          0 2px 8px rgba(0, 0, 0, 0.95);
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease;
      }

      .listen-button:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 230, 160, 1);
        box-shadow:
          0 0 20px rgba(255, 210, 106, 0.7),
          0 0 44px rgba(255, 210, 106, 0.34),
          inset 0 0 14px rgba(255, 255, 255, 0.1);
      }

      .listen-button:active {
        transform: translateY(0);
      }

      .listen-status {
        min-height: 20px;
        color: #ffe9a6;
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.95);
        opacity: 0.92;
        text-align: center;
      }

      audio {
        display: none;
      }

      @media (max-width: 900px) {
        .page {
          background-position: center center;
        }

        .top-nav {
          top: 14px;
          gap: 18px;
          padding: 9px 16px;
        }

        .listen-wrap {
          right: 6%;
          top: 50%;
          bottom: auto;
          left: auto;
          transform: translateY(-50%);
        }

        .listen-button {
          padding: 12px 22px;
        }
      }

      @media (max-width: 600px) {
        .top-nav {
          width: calc(100% - 28px);
          top: 12px;
          gap: 14px;
          padding: 9px 12px;
        }

        .top-nav a {
          font-size: 0.78rem;
          letter-spacing: 0.12em;
        }

        .hero-content {
          padding-top: 76px;
        }

        .listen-button {
          padding: 11px 18px;
          font-size: 0.76rem;
          letter-spacing: 0.06em;
          white-space: nowrap;
        }

        .listen-status {
          font-size: 0.72rem;
        }
      }

      /*
        PHONE PORTRAIT ONLY:
        This downsizes the homepage image and centers the Listen/Pause button
        under the OZONE image.
      */
      @media (max-width: 700px) and (orientation: portrait) {
        .page {
          min-height: 100svh;
          background-size: 92% auto;
          background-position: center 82px;
          background-repeat: no-repeat;
        }

        .hero-content {
          min-height: 100svh;
          padding: 76px 16px 30px;
        }

        .listen-wrap {
          left: 50%;
          right: auto;
          top: 72%;
          bottom: auto;
          transform: translateX(-50%);
          width: auto;
        }

        .listen-button {
          padding: 10px 18px;
          font-size: 0.74rem;
        }
      }

      @media (max-width: 430px) and (orientation: portrait) {
        .page {
          background-size: 88% auto;
          background-position: center 86px;
        }

        .listen-wrap {
          top: 71%;
        }
      }

      @media (max-width: 390px) and (orientation: portrait) {
        .page {
          background-size: 84% auto;
          background-position: center 88px;
        }

        .listen-wrap {
          top: 70%;
        }

        .listen-button {
          padding: 9px 15px;
          font-size: 0.68rem;
        }
      }

      @media (orientation: landscape) and (max-height: 520px) {
        .top-nav {
          top: 10px;
          padding: 7px 14px;
        }

        .hero-content {
          padding-top: 62px;
        }

        .listen-wrap {
          right: 6%;
          top: 50%;
          bottom: auto;
          left: auto;
          transform: translateY(-50%);
        }

        .listen-button {
          padding: 9px 18px;
          font-size: 0.72rem;
        }

        .listen-status {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <nav class="top-nav" aria-label="Main navigation">
        <a href="/">HOME</a>
        <a href="/store">STORE</a>
        <a href="/cart">CART</a>
      </nav>

      <section class="hero-content" aria-label="RLT Music and Film Works homepage">
        <div class="listen-wrap">
          <button id="listenButton" class="listen-button" type="button">
            ♫♫ Listen to ♫♫
          </button>

          <div id="listenStatus" class="listen-status" aria-live="polite"></div>

          <audio id="funkAudio" preload="auto">
            <source src={audioSrc} type="audio/mpeg" />
          </audio>
        </div>
      </section>
    </main>

    <script is:inline>
      const audio = document.getElementById("funkAudio");
      const listenButton = document.getElementById("listenButton");
      const listenStatus = document.getElementById("listenStatus");

      let hasPlayedOnce = false;

      function resetAudioToStart() {
        if (!audio) return;

        try {
          audio.currentTime = 0;
        } catch (error) {
          console.warn("Audio reset was not available yet.", error);
        }
      }

      async function toggleAudio() {
        if (!audio || !listenButton || !listenStatus) return;

        audio.volume = 1;

        if (!audio.paused) {
          audio.pause();
          listenButton.textContent = "♫♫ Listen to ♫♫";
          listenStatus.textContent = "Paused";
          return;
        }

        try {
          if (!hasPlayedOnce || audio.ended) {
            resetAudioToStart();
          }

          await audio.play();
          hasPlayedOnce = true;
          listenButton.textContent = "❚❚ Pause";
          listenStatus.textContent = "Now playing The Funk Strut";
        } catch (error) {
          listenButton.textContent = "♫♫ Listen to ♫♫";
          listenStatus.textContent = "Tap Listen again to start audio";
          console.warn("Audio playback was blocked or failed.", error);
        }
      }

      if (listenButton && audio) {
        listenButton.addEventListener("click", toggleAudio);

        audio.addEventListener("ended", () => {
          listenButton.textContent = "♫♫ Listen to ♫♫";
          listenStatus.textContent = "Tap Listen to play again";
        });

        audio.addEventListener("pause", () => {
          if (
            listenStatus &&
            hasPlayedOnce &&
            audio.currentTime > 0 &&
            !audio.ended
          ) {
            listenButton.textContent = "♫♫ Listen to ♫♫";
            listenStatus.textContent = "Paused";
          }
        });

        audio.addEventListener("play", () => {
          listenButton.textContent = "❚❚ Pause";
          listenStatus.textContent = "Now playing The Funk Strut";
        });
      }
    </script>
  </body>
</html>