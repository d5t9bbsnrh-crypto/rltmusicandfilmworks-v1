---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RLT Music & Filmworks</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: black;
        color: white;
        font-family: Arial, Helvetica, sans-serif;
        overflow-x: hidden;
      }

      .page {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* NAVIGATION */

      .nav {
        width: 100%;
        display: flex;
        justify-content: center;
        gap: 18px;
        padding: 24px 12px;
        flex-wrap: wrap;
        position: relative;
        z-index: 10;
      }

      .nav a {
        color: gold;
        text-decoration: none;
        border: 1px solid rgba(255, 215, 0, 0.55);
        padding: 12px 20px;
        font-size: 18px;
        letter-spacing: 2px;
        background: rgba(0, 0, 0, 0.65);
        border-radius: 6px;
        transition: 0.25s ease;
      }

      .nav a:hover {
        background: gold;
        color: black;
      }

      /* HERO IMAGE */

      .hero {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 20px;
        padding-bottom: 40px;
      }

      .hero img {
        width: 92%;
        max-width: 1400px;
        height: auto;
        object-fit: contain;
        display: block;
      }

      /* MOBILE */

      @media (max-width: 768px) {
        .nav {
          gap: 8px;
          padding: 14px 8px;
        }

        .nav a {
          font-size: 11px;
          padding: 9px 10px;
          letter-spacing: 1px;
        }

        .hero img {
          width: 96%;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- NAVIGATION -->

      <nav class="nav">
        <a href="/">HOME</a>
        <a href="/music">MUSIC</a>
        <a href="/films">FILMS</a>
        <a href="/store">STORE</a>
        <a href="/contacts">CONTACT</a>
        <a href="/cart">CART</a>
      </nav>

      <!-- HOMEPAGE IMAGE -->

      <section class="hero">
        <img
          src="/images/rlthomepage.png"
          alt="RLT Music & Filmworks"
        />
      </section>

    </div>
  </body>
</html>