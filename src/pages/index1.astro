<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />

    <title>RLT Music & Film Works</title>

    <style>
      /* =========================================
         PAGE LOAD PROTECTION
      ========================================= */

      body {
        visibility: hidden;
      }

      body.loaded {
        visibility: visible;
      }

      /* =========================================
         RESET
      ========================================= */

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        width: 100%;
        min-height: 100%;
        overflow-x: hidden;

        font-family: Arial, Helvetica, sans-serif;
        background: black;
        color: white;
      }

      a,
      button {
        touch-action: manipulation;
        position: relative;
        z-index: 100000;
      }

      /* =========================================
         NAVIGATION
      ========================================= */

      nav {
        width: 100%;
        padding: 24px 50px;

        display: flex;
        justify-content: center;
        align-items: center;
        gap: 40px;

        background: rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(10px);

        position: fixed;
        top: 0;
        left: 0;

        z-index: 99999;
        pointer-events: auto;
      }

      nav a {
        color: white;
        text-decoration: none;

        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 2px;

        transition: 0.3s ease;
      }

      nav a:hover {
        color: gold;
        transform: scale(1.05);
      }

      /* =========================================
         HERO
      ========================================= */

      .hero {
        position: relative;

        width: 100%;
        min-height: 100vh;

        display: flex;
        justify-content: center;
        align-items: center;

        overflow: hidden;
      }

      .hero img {
        width: 100%;
        height: 100vh;

        object-fit: cover;
        object-position: center;

        display: block;
      }

      /* =========================================
         HERO OVERLAY
      ========================================= */

      .hero-overlay {
        position: absolute;
        inset: 0;

        background: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.25),
          rgba(0, 0, 0, 0.45)
        );

        z-index: 2;

        /* IMPORTANT FIX */
        pointer-events: none;
      }

      /* =========================================
         CONTENT
      ========================================= */

      .hero-content {
        position: absolute;
        z-index: 10;

        text-align: center;

        width: 90%;
        max-width: 1200px;

        pointer-events: none;
      }

      .hero-content h1 {
        font-size: clamp(2.5rem, 6vw, 6rem);
        letter-spacing: 6px;

        color: white;
        text-shadow: 0 0 20px rgba(255