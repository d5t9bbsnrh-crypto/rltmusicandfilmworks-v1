<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RLT Cart</title>

    <style>
      body {
        margin: 0;
        padding: 0;
        background: #000;
        overflow: hidden;
        font-family: Arial, Helvetica, sans-serif;
      }

      .page {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
      }

      /* TOP NAVIGATION */

      .top-nav {
        position: absolute;
        top: 40px;
        right: 80px;
        z-index: 100;
        display: flex;
        gap: 30px;
      }

      .top-nav a {
        color: #ffd700;
        text-decoration: none;
        font-size: 20px;
        font-weight: bold;
        letter-spacing: 1px;
        transition: 0.3s ease;
      }

      .top-nav a:hover {
        color: white;
      }

      /* MAIN CART IMAGE */

      .cart-image {
        width: 100%;
        height: 100vh;
        object-fit: cover;
        display: block;
      }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- TOP LINKS -->

      <nav class="top-nav">
        <a href="/">HOME</a>
        <a href="/store">STORE</a>
        <a href="/cart">CART</a>
      </nav>

      <!-- CART IMAGE -->

      <img
        src="/images/hero/logos/Ozone-chart.png"
        alt="OZONE Cart"
        class="cart-image"
      />

    </div>
  </body>
</html>